server {
    listen 80;
    server_name llmstatus.io www.llmstatus.io;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name llmstatus.io www.llmstatus.io;

    ssl_certificate     /etc/nginx/ssl/llmstatus.crt;
    ssl_certificate_key /etc/nginx/ssl/llmstatus.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;

    # Pass real IP downstream to app services
    proxy_set_header X-Real-IP       $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Host            $host;

    # ── Go API (/v1/*, /badge/*, /feed.xml) ──────────────────────────────
    location /v1/ {
        proxy_pass http://127.0.0.1:18081;
        proxy_read_timeout 10s;
    }

    location /badge/ {
        proxy_pass http://127.0.0.1:18081;
        proxy_read_timeout 5s;
    }

    location = /feed.xml {
        proxy_pass http://127.0.0.1:18081;
        proxy_read_timeout 5s;
    }

    # ── Ingest API (probe nodes push here with INGEST_SECRET header) ──────
    location /ingest/ {
        proxy_pass http://127.0.0.1:18080/;
        proxy_read_timeout 10s;
    }

    # ── Next.js frontend (everything else) ───────────────────────────────
    location / {
        proxy_pass http://127.0.0.1:13000;
        proxy_read_timeout 30s;
        proxy_buffering off;
    }
}
